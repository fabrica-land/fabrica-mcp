{
  "name": "@fabrica-land/mcp",
  "version": "0.1.0",
  "description": "MCP server for AI agents to explore tokenized real property data on the Fabrica protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fabrica-mcp": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "fabrica",
    "real-estate",
    "tokenization",
    "ai",
    "ethereum",
    "nft"
  ],
  "author": "Fabrica",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
